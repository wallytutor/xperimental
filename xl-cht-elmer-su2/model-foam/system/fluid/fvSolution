FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system/fluid";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(rho|rhoFinal)"
    {
        // solver          diagonal;
        solver          PCG
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0;
    }


    p_rgh
    {
        solver           GAMG;
        smoother         symGaussSeidel;
        tolerance        1e-7;
        relTol           0.01;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol           0;
    }

    "(U|h|k|omega)"
    {
        solver           PBiCGStab;
        preconditioner   DILU;
        tolerance        1e-7;
        relTol           0.1;
    }

    "(U|h|k|omega)Final"
    {
        $U;
        relTol           0;
    }
}

PIMPLE
{
    momentumPredictor        yes;
    nCorrectors              2;
    nNonOrthogonalCorrectors 1;
    pRefCell                 101325.0;
    pRefValue                101325.0;
}

relaxationFactors
{
    equations
    {
        ".*" 1;
    }
}

