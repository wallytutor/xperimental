FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    fluidInlet
    {
        type            calculated;
        value           $internalField;
    }
    fluidOutlet
    {
        type            calculated;
        value           $internalField;
    }
    fluid_to_solid
    {
        type            nutkWallFunction;
        value           uniform 0;
    }
    "cyclicFluid(Left|Right)"
    {
        type            cyclic;
    }
}


