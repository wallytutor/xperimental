FoamFile
{
    format      ascii;
    class       volScalarField;
    object      alphat.gas;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -1 0 0 0 0];

internalField   uniform 1.0e-08;

boundaryField
{
    fluidInlet
    {
        type            calculated;
        value           $internalField;
    }
    fluidOutlet
    {
        type            calculated;
        value           $internalField;
    }
    fluid_to_solid
    {
        // TODO check this!
        type            calculated;
        value           $internalField;
    }
    "cyclicFluid(Left|Right)"
    {
        type            cyclic;
    }
}


