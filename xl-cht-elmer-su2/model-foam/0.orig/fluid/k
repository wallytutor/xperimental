FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    fluidInlet
    {
        type            mappedInternalValue;
        interpolationScheme cell;
        value           uniform 0.01;
    }
    fluidOutlet
    {
        type            inletOutlet;
        phi             phi;
        inletValue      uniform 0.01;
        value           uniform 0.01;
    }
    fluid_to_solid
    {
        type            kqRWallFunction;
        value           uniform 0.01;
    }
    "cyclicFluid(Left|Right)"
    {
        type            cyclic;
    }
}


