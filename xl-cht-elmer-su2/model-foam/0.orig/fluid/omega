FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    fluidInlet
    {
        type            mappedInternalValue;
        interpolationScheme cell;
        value           uniform 0.01;
    }
    fluidOutlet
    {
        type            inletOutlet;
        phi             phi.liquid;
        inletValue      uniform 0.0015;
        value           uniform 0.01;
    }
    fluid_to_solid
    {
        type            omegaWallFunction;
        Cmu             0.09;
        kappa           0.41;
        E               9.8;
        value           uniform 0.001;
    }
    "cyclicFluid(Left|Right)"
    {
        type            cyclic;
    }
}


