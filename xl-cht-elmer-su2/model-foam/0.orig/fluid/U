FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0/fluid";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 1 -1 0 0 0 0 ];

#include "../../constant/userParameters"

internalField   uniform (0 0 $inletVelocity);

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    fluidInlet
    {
        type            fixedValue;
        value           uniform (0 0 $inletVelocity);
    }
    fluidOutlet
    {
        type            pressureInletOutletVelocity;
        value           $internalField;
    }
    fluid_to_solid
    {
        type            noSlip;
    }
    "fluid(Left|Right)|solid(Left|Right)"
    {
        type            cyclic;
    }
}

