FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/solid";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 0 1 0 0 0 ];

#include "../../constant/userParameters"

internalField   uniform $solidTemperature;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    "solid(Top|Bottom)"
    {
        type            externalTemperature;
        Ta              constant 300.0;
        h               uniform 10.0;
        thicknessLayers (0.25);
        kappaLayers     (2.0);
        value           $internalField;
    }
    solidSymmetry
    {
        type            zeroGradient;
    }
    solid_to_fluid
    {
        type            coupledTemperature;
        value           $internalField;
    }
    "cyclic.*"
    {
        type            cyclic;
    }
}


