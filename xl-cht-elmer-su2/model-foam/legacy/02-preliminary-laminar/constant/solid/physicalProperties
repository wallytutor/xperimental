FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/solid";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType  constSolidThermo;

rho
{
    type        uniform;
    value       2800.0;
}

Cv
{
    type        uniform;
    value       1000.0;
}

kappa
{
    type        uniform;
    value       2.0;
}

