//
// "0.orig/fluid/U"
//
FoamFile
{
    format          ascii;
    class           volVectorField;
    location        "0/fluid";
    object          U;
}

dimensions      [ 0 1 -1 0 0 0 0 ];

fluidTemperature 873.15;

solidTemperature 298.15;

inletVelocity   10.5;

nProcs          4;

internalField   uniform ( 0 0 10.5 );

boundaryField
{
    cyclic
    {
        type            cyclic;
    }
    cyclicSlip
    {
        type            cyclicSlip;
    }
    nonConformalCyclic
    {
        type            nonConformalCyclic;
        value           uniform ( 0 0 10.5 );
    }
    nonConformalError
    {
        type            nonConformalError;
    }
    empty
    {
        type            empty;
    }
    processor
    {
        type            processor;
        value           uniform ( 0 0 10.5 );
    }
    processorCyclic
    {
        type            processorCyclic;
        value           uniform ( 0 0 10.5 );
    }
    nonConformalProcessorCyclic
    {
        type            nonConformalProcessorCyclic;
        value           uniform ( 0 0 10.5 );
    }
    symmetryPlane
    {
        type            symmetryPlane;
    }
    symmetry
    {
        type            symmetry;
    }
    wedge
    {
        type            wedge;
    }
    internal
    {
        type            internal;
    }
    fluidInlet
    {
        type            fixedValue;
        value           uniform ( 0 0 10.5 );
    }
    fluidOutlet
    {
        type            pressureInletOutletVelocity;
        value           uniform ( 0 0 10.5 );
    }
    fluid_to_solid
    {
        type            noSlip;
    }
    "fluid(Left|Right)|solid(Left|Right)"
    {
        type            cyclic;
    }
}


