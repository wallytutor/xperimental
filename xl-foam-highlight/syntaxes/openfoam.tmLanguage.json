{
  "name": "OpenFOAM Dictionary",
  "scopeName": "source.openfoam-dict",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor"
    },
    {
      "include": "#dictionaryBlock"
    },
    {
      "include": "#dictionaryEntry"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#delimiters"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.openfoam",
          "match": "//.*$"
        },
        {
          "name": "comment.block.openfoam",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.openfoam",
          "match": "^\\s*#(?:include|includeEtc|inputMode|remove|codeStream|calc)\\b"
        }
      ]
    },
    "dictionaryBlock": {
      "patterns": [
        {
          "name": "meta.block.dictionary.openfoam",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_.-]*)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "entity.name.section.openfoam"
            },
            "2": {
              "name": "punctuation.section.block.begin.openfoam"
            }
          }
        }
      ]
    },
    "dictionaryEntry": {
      "patterns": [
        {
          "name": "meta.entry.dictionary.openfoam",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_.-]*)\\s+([^;{}]+?)\\s*(;)",
          "captures": {
            "1": {
              "name": "variable.other.key.openfoam"
            },
            "2": {
              "name": "string.unquoted.value.openfoam"
            },
            "3": {
              "name": "punctuation.terminator.statement.openfoam"
            }
          }
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.openfoam",
          "match": "\\b(?:on|off|yes|no|true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.openfoam",
          "match": "(?<![A-Za-z0-9_.-])[+-]?(?:\\d+\\.\\d*|\\d*\\.\\d+|\\d+)(?:[eE][+-]?\\d+)?(?![A-Za-z0-9_.-])"
        }
      ]
    },
    "delimiters": {
      "patterns": [
        {
          "name": "punctuation.section.braces.begin.openfoam",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.openfoam",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.openfoam",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.openfoam",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.begin.openfoam",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.openfoam",
          "match": "\\)"
        }
      ]
    }
  }
}
